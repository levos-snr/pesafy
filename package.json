{
  "name": "pesafy",
  "version": "0.5.4",
  "private": false,
  "description": "Type-safe M-PESA Daraja SDK for Node.js, Bun, Deno, Cloudflare Workers, and all JS frameworks",
  "keywords": [
    "africa",
    "b2b",
    "b2c",
    "c2b",
    "daraja",
    "express",
    "fastify",
    "fintech",
    "gateway",
    "hono",
    "kenya",
    "kra",
    "mpesa",
    "nextjs",
    "payment",
    "pesafy",
    "safaricom",
    "stk-push",
    "tax-remittance",
    "typescript"
  ],
  "homepage": "https://pesafy.vercel.app",
  "bugs": {
    "url": "https://github.com/levos-snr/pesafy/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lewis Odero",
    "email": "lewisodero27@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levos-snr/pesafy.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "bin": {
    "pesafy": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters/express": {
      "types": "./dist/adapters/express.d.ts",
      "default": "./dist/adapters/express.js"
    },
    "./adapters/hono": {
      "types": "./dist/adapters/hono.d.ts",
      "default": "./dist/adapters/hono.js"
    },
    "./adapters/nextjs": {
      "types": "./dist/adapters/nextjs.d.ts",
      "default": "./dist/adapters/nextjs.js"
    },
    "./adapters/fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "default": "./dist/adapters/fastify.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./cli": {
      "default": "./dist/cli.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "changeset": "changeset",
    "version-bump": "changeset version",
    "release": "changeset publish --access public",
    "cli": "node dist/cli.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "size-limit": "size-limit",
    "size": "pnpm build && size-limit",
    "size:why": "pnpm build && size-limit --why",
    "check:all": "pnpm lint && pnpm format:check && pnpm typecheck"
  },
  "size-limit": [
    {
      "name": "Core (index)",
      "path": "dist/index.js",
      "limit": "35 kB"
    },
    {
      "name": "Adapter: Express",
      "path": "dist/adapters/express.js",
      "limit": "15 kB"
    },
    {
      "name": "Adapter: Hono",
      "path": "dist/adapters/hono.js",
      "limit": "5 kB"
    },
    {
      "name": "Adapter: Next.js",
      "path": "dist/adapters/nextjs.js",
      "limit": "5 kB"
    },
    {
      "name": "Adapter: Fastify",
      "path": "dist/adapters/fastify.js",
      "limit": "5 kB"
    },
    {
      "name": "React",
      "path": "dist/react/index.js",
      "limit": "1 kB"
    }
  ],
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.2"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "express": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "hono": "^4.4.0",
    "lint-staged": "^16.4.0",
    "oxlint": "latest",
    "prettier": "^3.5.3",
    "publint": "^0.3.12",
    "simple-git-hooks": "^2.13.0",
    "size-limit": "^12.0.1",
    "size-limit-preset-node-lib": "^0.4.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitepress": "catalog:",
    "vitest": "^4.1.2",
    "vue": "^3.5.31"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "react": ">=18.0.0",
    "typescript": "^5",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "workspaces": {
    "packages": [
      "."
    ]
  }
}
