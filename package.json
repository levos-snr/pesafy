{
  "name": "pesafy",
  "version": "0.5.1",
  "private": false,
  "description": "Type-safe M-PESA Daraja SDK for Node.js, Bun, Deno, Cloudflare Workers, and all JS frameworks",
  "keywords": [
    "b2b",
    "b2c",
    "c2b",
    "daraja",
    "express",
    "fastify",
    "fintech",
    "gateway",
    "hono",
    "kenya",
    "mpesa",
    "nextjs",
    "payment",
    "pesafy",
    "safaricom",
    "stk-push",
    "tax-remittance"
  ],
  "homepage": "https://pesafy.vercel.app",
  "bugs": {
    "url": "https://github.com/levos-snr/pesafy/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lewis Odero",
    "email": "lewisodero27@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levos-snr/pesafy.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pesafy": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/express": {
      "import": {
        "types": "./dist/adapters/express.d.ts",
        "default": "./dist/adapters/express.js"
      },
      "require": {
        "types": "./dist/adapters/express.d.cts",
        "default": "./dist/adapters/express.cjs"
      }
    },
    "./adapters/hono": {
      "import": {
        "types": "./dist/adapters/hono.d.ts",
        "default": "./dist/adapters/hono.js"
      },
      "require": {
        "types": "./dist/adapters/hono.d.cts",
        "default": "./dist/adapters/hono.cjs"
      }
    },
    "./adapters/nextjs": {
      "import": {
        "types": "./dist/adapters/nextjs.d.ts",
        "default": "./dist/adapters/nextjs.js"
      },
      "require": {
        "types": "./dist/adapters/nextjs.d.cts",
        "default": "./dist/adapters/nextjs.cjs"
      }
    },
    "./adapters/fastify": {
      "import": {
        "types": "./dist/adapters/fastify.d.ts",
        "default": "./dist/adapters/fastify.js"
      },
      "require": {
        "types": "./dist/adapters/fastify.d.cts",
        "default": "./dist/adapters/fastify.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      }
    },
    "./cli": {
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "pnpm typecheck && pnpm build",
    "changeset": "changeset",
    "version-bump": "changeset version",
    "release": "changeset publish --access public",
    "cli": "node dist/cli.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "express": "^5.2.1",
    "lint-staged": "^16.4.0",
    "oxlint": "latest",
    "prettier": "^3.5.3",
    "publint": "^0.3.12",
    "simple-git-hooks": "^2.13.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.7.2",
    "vitepress": "next",
    "vitest": "^4.1.2",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "react": ">=18.0.0",
    "typescript": "^5",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": {
    "packages": [
      "pesafy"
    ],
    "catalog": {
      "vitepress": "^1.6.3",
      "vue": "^3.5.13"
    }
  }
}
